#Ejercicio ejemplo
class Carro:
  def __init__(self):
    self.placa = " "
    self.modelo = " "
    self.fecha_entrada = " "
    self.hora_entrada = " "

  def registrar_entrada(self):
    info = f"entrada vehiculo{self.fecha_entrada}"
    info = info + f"hora_entrada{self.hora_entrada}"
    return info

  def get_placa(self):
    return self.placa

  def set_placa(self, nuevo_dato):
    self.placa = nuevo_dato

class Carro_publico(Carro):
  def __init__(self, dato_matricula):
    super().__init()
    self.matricula = dato_matricula

  def get_matricula(self):
    return self.matricula

  def set_matricula(self, nuevo_dato):
    self.matricula = nuevo_dato

  def ver_info(self):
    info = super().get_placa()
    info = info + self.matricula
    return info


#codigo principal

carro_pequeño = Carro()
carro_grande = Carro()
carro_pesado = Carro_publico(True)
carro_pesado.ver_info()

